UNAME := $(shell uname)

ifeq ($(UNAME), Linux)
# Linux
	SHARED_FLAG = -shared
else
	ifeq ($(UNAME), Darwin)
# OS X
		SHARED_FLAG = -dynamiclib
	endif
endif

CXX = @CXX@
NVCC = nvcc
CXXFLAGS = -Wall -fopenmp -O3 -march=native -DNDEBUG -std=c++14

INCLUDES = -I@EIGEN_DIR@ -I@BOOST_DIR@
LDFLAGS = @LDFLAGS@ -lpthread

all: Grid.o Grid_ctypes.o Grid.cpp Grid.hpp Grid_ctypes.cpp Grid_ctypes.hpp fdtd.o fdtd.cpp fdtd.hpp fdtd.cu
	${CXX} ${SHARED_FLAG} -fopenmp -fPIC -o Grid.so Grid.o Grid_ctypes.o ${LDFLAGS}
	${CXX} ${SHARED_FLAG} -fopenmp -fPIC -o FDTD.so fdtd.o ${LDFLAGS}
	${NVCC} -Xcompiler -fPIC -O3 -std=c++17 -arch=native -shared fdtd.cu -o FDTD_gpu.so
	cp Grid.so ../emopt
	cp FDTD.so ../emopt/solvers
	cp FDTD_gpu.so ../emopt/solvers

Grid.o: Grid.cpp Grid.hpp
	${CXX} -c -fPIC Grid.cpp ${CXXFLAGS} -o Grid.o ${INCLUDES}

Grid_ctypes.o: Grid.cpp Grid.hpp Grid_ctypes.cpp Grid_ctypes.hpp
	${CXX} -c -fPIC Grid_ctypes.cpp ${CXXFLAGS} -o Grid_ctypes.o ${INCLUDES}

fdtd.o: fdtd.cpp fdtd.hpp
	${CXX} -c -fPIC fdtd.cpp ${CXXFLAGS} -o fdtd.o

clean:
	rm -f ./*.o
	rm -f ./*.so

